{
  "rules": [
    {
      "id": "SEC-001",
      "name": "No Secrets",
      "pattern": "sk-[A-Za-z0-9-_]{20,}|AKIA[A-Za-z0-9]{16}",
      "severity": "critical",
      "message": "Potential secret leakage detected."
    },
    {
      "id": "ARCH-001",
      "name": "Module Privacy",
      "pattern": "import .*? from '.*?/internal/.*?/priv_.*?'",
      "severity": "hard",
      "message": "Do not import from private sub-modules."
    }
  ]
}
